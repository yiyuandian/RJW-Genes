<LanguageData>
    <rjw_genes_animal_inheritance_settings_enabled_key>启用</rjw_genes_animal_inheritance_settings_enabled_key>
    <rjw_genes_animal_inheritance_settings_enabled_explanation>如果启用，动物怀孕将尝试继承基因。</rjw_genes_animal_inheritance_settings_enabled_explanation>

    <rjw_genes_animal_inheritance_settings_chance_key>几率</rjw_genes_animal_inheritance_settings_chance_key>
